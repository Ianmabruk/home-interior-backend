# Frontend environment variables (Vite)
# Copy this file to `.env` and adjust as needed.
# Vite only exposes variables prefixed with VITE_ to the client.

# Base URL for the backend API.
# - Leave empty/unset to use a relative "/api" path. This works automatically
#   with the Vite dev proxy (server.proxy in vite.config.js) and with
#   same-origin production deployments (e.g. when the backend serves the SPA or
#   sits behind the same domain).
# - Set this explicitly for cross-origin deployments, e.g. a Render backend
#   consumed by a Vercel/Netlify frontend:
# VITE_API_URL=https://<your-render-backend>.onrender.com/api
VITE_API_URL=
