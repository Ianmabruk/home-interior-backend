generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String     @id @default(uuid()) @map("_id")
  fullName             String     @map("full_name")
  email                String     @unique
  passwordHash         String     @map("password_hash")
  role                 String     @default("user")
  isActive             Boolean?   @default(true) @map("is_active")
  phone                String?
  lastLoginAt          DateTime?  @map("last_login_at")
  refreshToken         String?    @map("refresh_token")
  passwordResetToken   String?    @map("password_reset_token")
  passwordResetExpires DateTime?  @map("password_reset_expires")
  cart                 Json?
  addresses            Json?
  createdAt            DateTime   @default(now()) @map("created_at")
  updatedAt            DateTime   @updatedAt @map("updated_at")
  orders               Order[]    @relation("UserOrders")
  sentMessages         Message[]  @relation("MessageSender")
  wishlist             Wishlist?

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@map("users")
}

model Portfolio {
  id           String   @id @default(uuid()) @map("_id")
  title        String?
  description  String?
  category     String?  @default("General") @map("category")
  imageUrl     String?  @map("image_url")
  mediaUrls    Json?    @map("media_urls")
  cloudinaryId String?  @map("cloudinary_id")
  featured     Boolean  @default(false)
  displayOrder Int      @default(0) @map("display_order")
  published    Boolean  @default(true)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([featured])
  @@index([displayOrder])
  @@index([published])
  @@index([createdAt])
  @@map("portfolios")
}

model Product {
  id            String   @id @default(uuid()) @map("_id")
  name          String
  description   String
  price         Float
  discountPrice Float?   @map("discount_price")
  colorVariants Json?
  sku           String?
  images        Json
  category      String
  stock         Int      @default(0)
  isPublished   Boolean  @default(true) @map("is_published")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([isPublished])
  @@index([category])
  @@index([createdAt])
  @@map("products")
}

model VirtualDesign {
  id           String   @id @default(uuid()) @map("_id")
  title        String
  description  String?
  category     String   @default("General") @map("category")
  mediaUrl     String?  @map("media_url")
  mediaType    String?  @default("image") @map("media_type")
  mediaUrls    Json?    @map("media_urls")
  cloudinaryId String?  @map("cloudinary_id")
  featured     Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([featured])
  @@index([createdAt])
  @@map("virtual_designs")
}

model Service {
  id           String   @id @default(uuid()) @map("_id")
  title        String
  description  String
  icon         String
  imageUrl     String?  @map("image_url")
  cloudinaryId String?  @map("cloudinary_id")
  featured     Boolean  @default(false)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@index([featured])
  @@index([displayOrder])
  @@index([isActive])
  @@map("services")
}

model About {
  id                 String   @id @default(uuid()) @map("_id")
  aboutImageUrl      String?  @map("about_image_url")
  aboutImagePublicId String?  @map("about_image_public_id")
  story              String
  companyDescription String   @map("company_description")
  mission            String
  vision             String
  location           String
  contactEmail       String   @map("contact_email")
  socials            Json
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("abouts")
}

model Hero {
  id           String   @id @default(uuid()) @map("_id")
  title        String?
  subtitle     String?
  imageUrl     String?  @map("image_url")
  mediaUrls    Json?    @map("media_urls")
  cloudinaryId String?  @map("cloudinary_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("hero")
}

model Message {
  id        String   @id @default(uuid()) @map("_id")
  senderId  String?  @map("sender_id")
  sender    User?    @relation("MessageSender", fields: [senderId], references: [id], onDelete: SetNull)
  name      String
  email     String
  subject   String
  content   String
  isRead    Boolean? @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([senderId])
  @@index([isRead])
  @@map("messages")
}

model Order {
  id              String   @id @default(uuid()) @map("_id")
  userId          String   @map("user_id")
  user            User     @relation("UserOrders", fields: [userId], references: [id], onDelete: Cascade)
  items           Json
  subtotal        Float
  shippingFee     Float    @default(0) @map("shipping_fee")
  total           Float
  status          String   @default("pending")
  paymentStatus   String   @default("pending") @map("payment_status")
  shippingAddress Json?   @map("shipping_address")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("orders")
}

model Settings {
  id              String   @id @default(uuid()) @map("_id")
  siteName        String?  @default("HOK Interior Designs") @map("site_name")
  supportEmail    String?  @default("info@hokinterior.com") @map("support_email")
  maintenanceMode Boolean? @default(false) @map("maintenance_mode")
  currency        String?  @default("USD")
  shippingPolicy  String?  @default("") @map("shipping_policy")
  returnPolicy    String?  @default("") @map("return_policy")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model Consultation {
  id             String   @id @default(uuid()) @map("_id")
  name           String
  email          String
  phone          String?
  message        String
  preferredDate  String?
  preferredTime  String?
  status         String   @default("new")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([createdAt])
  @@map("consultations")
}

model Testimonial {
  id              String   @id @default(uuid()) @map("_id")
  clientName      String   @map("client_name")
  position        String?
  company         String?
  testimonial     String
  rating          Int      @default(5)
  photoUrl        String?  @map("photo_url")
  photoPublicId   String?  @map("photo_public_id")
  displayOrder    Int      @default(0) @map("display_order")
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([displayOrder])
  @@index([isActive])
  @@map("testimonials")
}

model Wishlist {
  id         String   @id @default(uuid()) @map("_id")
  userId     String   @unique @map("user_id")
  products   Json
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wishlists")
}
