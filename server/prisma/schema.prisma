generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  relationMode = "prisma"
}

enum ProductCategory {
  Mirrors
  Frames
  ThrowPillows @map("Throw Pillows")
}

model User {
  id                   String    @id @default(uuid()) @map("_id")
  fullName             String    @map("full_name")
  email                String    @unique
  passwordHash         String    @map("password_hash")
  role                 String    @default("user")
  avatarUrl            String?   @map("avatar_url")
  phone                String?
  refreshToken         String?   @map("refresh_token")
  passwordResetToken   String?   @map("password_reset_token")
  passwordResetExpires DateTime? @map("password_reset_expires")
  isActive             Boolean?  @default(true) @map("is_active")
  lastLoginAt          DateTime? @map("last_login_at")
  cart                 Json?
  addresses            Json?
  createdAt            DateTime  @default(now()) @map("created_at")
  updatedAt            DateTime  @updatedAt @map("updated_at")

  wishlist     Wishlist?
  orders       Order[]
  sentMessages Message[] @relation("MessageSender")

  @@map("users")
}

model Wishlist {
  id        String   @id @default(uuid()) @map("_id")
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  products  Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("wishlists")
}

model Order {
  id              String   @id @default(uuid()) @map("_id")
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items           Json
  subtotal        Float
  shippingFee     Float    @default(0) @map("shipping_fee")
  total           Float
  status          String   @default("pending")
  paymentStatus   String   @default("pending") @map("payment_status")
  shippingAddress Json?    @map("shipping_address")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("orders")
}

model Product {
  id            String   @id @default(uuid()) @map("_id")
  name          String
  description   String
  price         Float
  discountPrice Float?   @map("discount_price")
  images        Json
  colorVariants Json     @map("color_variants")
  category      ProductCategory
  vendor        String?  @default("")
  stock         Int
  sku           String   @unique
  tags          Json
  mediaSettings Json?    @map("media_settings")
  isFeatured    Boolean? @default(false) @map("is_featured")
  isPublished   Boolean? @default(true) @map("is_published")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  productImages ProductImage[]

  @@index([isPublished])
  @@index([category])
  @@index([isFeatured])
  @@index([createdAt])
  @@map("products")
}

// Relational product images (unlimited). Existing `images` JSON column is kept
// as the primary store; ProductImage supports ordered, individually managed images.
model ProductImage {
  id        String   @id @default(uuid()) @map("_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String   @map("product_id")
  imageUrl  String   @map("image_url")
  publicId  String?  @map("public_id")
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([productId])
  @@index([sortOrder])
  @@map("product_images")
}

model Portfolio {
  id                 String          @id @default(uuid()) @map("_id")
  title              String?
  description        String?
  imageUrl           String          @map("image_url")
  featuredImage      String?         @map("featured_image")
  galleryImages      String[]        @default([]) @map("gallery_images")
  beforeAfterImages  Json?           @map("before_after_images")
  gallery            Json?           @map("gallery")
  cloudinaryId       String?         @map("cloudinary_id")
  featured           Boolean         @default(false)
  published          Boolean         @default(true) @map("published")
  displayOrder       Int             @default(0) @map("display_order")
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  media              PortfolioMedia[]

  @@index([featured])
  @@index([published])
  @@index([displayOrder])
  @@index([createdAt])
  @@map("portfolios")
}

// Relational media for Portfolio (unlimited records, ordered by sortOrder).
// Existing galleryImages JSON column is preserved as a fallback for backwards
// compatibility; new uploads should use PortfolioMedia.
model PortfolioMedia {
  id          String   @id @default(uuid()) @map("_id")
  portfolio   Portfolio @relation(fields: [portfolioId], references: [id], onDelete: Cascade)
  portfolioId String   @map("portfolio_id")
  imageUrl    String   @map("image_url")
  publicId    String?  @map("public_id")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([portfolioId])
  @@index([sortOrder])
  @@map("portfolio_media")
}

model Project {
  id            String   @id @default(uuid()) @map("_id")
  title         String?
  description   String?
  tags          String[]
  services      String[]
  media         Json?
  mediaSettings Json?    @map("media_settings")
  thumbnailUrl  String?  @map("thumbnail_url")
  thumbnailPublicId String? @map("thumbnail_public_id")
  isPublished   Boolean  @default(true) @map("is_published")
  order         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([isPublished])
  @@index([order])
  @@map("projects")
}

model ProjectV2 {
  id            String   @id @default(uuid()) @map("_id")
  videoUrl      String   @map("video_url")
  videoPublicId String   @map("video_public_id")
  thumbnailUrl  String?  @map("thumbnail_url")
  order         Int      @default(0)
  isPublished   Boolean  @default(true) @map("is_published")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([order])
  @@index([isPublished])
  @@map("project_v2")
}

model About {
  id                 String   @id @default(uuid()) @map("_id")
  aboutImageUrl      String?  @map("about_image_url")
  aboutImagePublicId String?  @map("about_image_public_id")
  mediaSettings      Json?    @map("media_settings")
  story              String
  companyDescription String   @map("company_description")
  mission            String
  vision             String
  location           String
  contactEmail       String   @map("contact_email")
  socials            Json
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  @@map("abouts")
}

model VirtualDesign {
  id           String           @id @default(uuid()) @map("_id")
  title        String
  description  String?
  mediaType    String
  mediaUrl     String           @map("media_url")
  featuredImage String?         @map("featured_image")
  galleryMedia String[]         @default([]) @map("gallery_media")
  cloudinaryId String?          @map("cloudinary_id")
  featured     Boolean          @default(false)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  media        VirtualDesignMedia[]

  @@index([featured])
  @@index([createdAt])
  @@map("virtual_designs")
}

// Relational media for VirtualDesign (unlimited, ordered by sortOrder).
// Existing galleryMedia JSON column is preserved as a fallback.
model VirtualDesignMedia {
  id           String        @id @default(uuid()) @map("_id")
  virtualDesign VirtualDesign @relation(fields: [virtualDesignId], references: [id], onDelete: Cascade)
  virtualDesignId String     @map("virtual_design_id")
  imageUrl     String        @map("image_url")
  publicId     String?       @map("public_id")
  sortOrder    Int           @default(0) @map("sort_order")
  createdAt    DateTime      @default(now()) @map("created_at")

  @@index([virtualDesignId])
  @@index([sortOrder])
  @@map("virtual_design_media")
}

model Settings {
  id              String   @id @default(uuid()) @map("_id")
  siteName        String?  @default("HOK Interior Designs") @map("site_name")
  supportEmail    String?  @default("info@hokinterior.com") @map("support_email")
  maintenanceMode Boolean? @default(false) @map("maintenance_mode")
  currency        String?  @default("USD")
  shippingPolicy  String?  @default("") @map("shipping_policy")
  returnPolicy    String?  @default("") @map("return_policy")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("settings")
}

model NewsletterSubscription {
  id        String   @id @default(uuid()) @map("_id")
  email     String   @unique
  source    String?  @default("website")
  isActive  Boolean? @default(true) @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("newsletter_subscriptions")
}

model Analytics {
  id        String   @id @default(uuid()) @map("_id")
  date      DateTime @unique
  visits    Int?     @default(0)
  revenue   Int?     @default(0)
  orders    Int?     @default(0)
  newUsers  Int?     @default(0) @map("new_users")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("analytics")
}

model Message {
  id        String   @id @default(uuid()) @map("_id")
  senderId  String?  @map("sender_id")
  sender    User?    @relation("MessageSender", fields: [senderId], references: [id], onDelete: SetNull)
  name      String
  email     String
  subject   String
  content   String
  isRead    Boolean? @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("messages")
}

model Service {
  id            String   @id @default(uuid()) @map("_id")
  title         String
  description   String
  icon          String
  imageUrl      String?  @map("image_url")
  cloudinaryId  String?  @map("cloudinary_id")
  mediaSettings Json?    @map("media_settings")
  featured      Boolean  @default(false)
  displayOrder  Int      @default(0) @map("display_order")
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@index([featured])
  @@index([displayOrder])
  @@index([isActive])
  @@map("services")
}

model Testimonial {
  id           String   @id @default(uuid()) @map("_id")
  clientName   String   @map("client_name")
  position     String?
  company      String?
  testimonial  String
  photoUrl     String?  @map("photo_url")
  photoPublicId String? @map("photo_public_id")
  rating       Int      @default(5)
  displayOrder Int      @default(0) @map("display_order")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("testimonials")
}

model HomepageContent {
  id           String   @id @default(uuid()) @map("_id")
  heroImages   String[] @default([]) @map("hero_images")
  title        String?
  subtitle     String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("homepage_content")
}

// Canonical homepage settings: hero slider images, hero text, hero buttons,
// and featured portfolio project references. Replaces the ad-hoc HomepageContent
// shape with a structured, admin-editable model.
model HomepageSettings {
  id              String   @id @default(uuid()) @map("_id")
  heroImages      String[] @default([]) @map("hero_images")
  heroTitle       String?  @map("hero_title")
  heroSubtitle    String?  @map("hero_subtitle")
  heroButtons     Json?    @map("hero_buttons")
  featuredPortfolioIds String[] @default([]) @map("featured_portfolio_ids")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@map("homepage_settings")
}

model Consultation {
  id        String   @id @default(uuid()) @map("_id")
  name      String
  email     String
  phone     String?
  message   String
  status    String   @default("new")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("consultations")
}