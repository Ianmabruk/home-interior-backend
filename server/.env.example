NODE_ENV=production
PORT=5000
# Frontend origin(s) allowed by CORS. Comma-separated if more than one.
CLIENT_URL=https://your-site.netlify.app
# Neon PostgreSQL connection string with pooler (REQUIRED for production on Render)
# Use the pooled connection string from Neon dashboard: postgres://user:pass@ep-xxx-pooler.region.aws.neon.tech/db?sslmode=require&pgbouncer=true
# For Render: set DATABASE_URL to the pooled connection string with sslmode=require&pgbouncer=true&connect_timeout=15
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require&pgbouncer=true&connect_timeout=15
# Generate strong unique values, e.g. `openssl rand -hex 32`
JWT_ACCESS_SECRET=replace-with-strong-random-secret
JWT_REFRESH_SECRET=replace-with-another-strong-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloud-api-key
CLOUDINARY_API_SECRET=your-cloud-api-secret
SENDGRID_API_KEY=SG.replace-with-sendgrid-key
EMAIL_FROM=info@yourdomain.com
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=change-this-strong-password
