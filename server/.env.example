NODE_ENV=production
PORT=5000
# Frontend origin(s) allowed by CORS. Comma-separated if more than one.
CLIENT_URL=https://your-site.netlify.app

# ┌─────────────────────────────────────────────────────────────┐
# │ SUPABASE POSTGRESQL CONNECTION STRING                       │
# │                                                             │
# │ CRITICAL: Use the Supabase pooler endpoint for production.  │
# │ The direct endpoint (db.<project>.supabase.co) is often     │
# │ IPv6-only and unreachable from Render / IPv4 networks.     │
# │                                                             │
# │ Steps to get the correct URL:                               │
# │ 1. Open Supabase Dashboard → Settings → Database           │
# │ 2. Copy the "Supavisor (transaction mode)" connection string│
# │ 3. It will look like:                                       │
# │    postgresql://postgres:<PASSWORD>@                       │
# │    aws-0-<region>.pooler.supabase.com:6543/postgres        │
# │    ?sslmode=require&connect_timeout=15                     │
# │                                                             │
# │ For Render: paste the exact pooler string from Supabase.    │
# │ For local dev: see DATABASE_AUDIT.md for IPv6/tunnel options│
# └─────────────────────────────────────────────────────────────┘
DATABASE_URL=postgresql://postgres:PASSWORD@db.amcaogrlsrwxbvuglyle.supabase.co:5432/postgres?pgbouncer=true&connection_limit=1
DIRECT_URL=postgresql://postgres:PASSWORD@db.amcaogrlsrwxbvuglyle.supabase.co:5432/postgres
# Generate strong unique values, e.g. `openssl rand -hex 32`
JWT_ACCESS_SECRET=replace-with-strong-random-secret
JWT_REFRESH_SECRET=replace-with-another-strong-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=30d
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloud-api-key
CLOUDINARY_API_SECRET=your-cloud-api-secret
EMAIL_FROM=info@yourdomain.com
SEED_ADMIN_EMAIL=admin@yourdomain.com
SEED_ADMIN_PASSWORD=change-this-strong-password
