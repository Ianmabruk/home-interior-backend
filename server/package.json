{
  "name": "hok-interior-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon src/server.js",
    "start": "node src/index.js",
    "build": "prisma generate",
    "lint": "node --check src/server.js",
    "seed": "node src/seeds/seed.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js --watch",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "@supabase/supabase-js": "^2.49.1",
    "bcryptjs": "^3.0.2",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/node": "^26.1.1",
    "jest": "^30.0.2",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.10",
    "prisma": "^6.8.2",
    "supertest": "^7.1.4"
  }
}
