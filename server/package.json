{
  "name": "hok-interior-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --env-file=.env src/index.js",
    "start": "node --env-file=.env src/index.js",
    "build": "prisma generate",
    "postinstall": "prisma generate",
    "fixFailedMigration": "node scripts/fixFailedMigration.js",
    "lint": "node --check src/index.js",
    "seed": "node src/seeds/seed.js",
    "seed:admin": "node src/seeds/seedAdmin.js",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js",
    "test:watch": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js --coverage",
    "test:ci": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.config.js --ci --reporters=default --reporters=jest-junit"
  },
  "dependencies": {
    "@prisma/client": "6.19.3",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.7.0",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "pg": "^8.13.4",
    "streamifier": "^0.1.1",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/node": "^26.1.1",
    "jest": "^30.0.2",
    "jest-junit": "^16.0.0",
    "nodemon": "^3.1.10",
    "prisma": "6.19.3",
    "supertest": "^7.1.4"
  }
}
